<jqassistant-rules xmlns="http://schema.jqassistant.org/rule/v1.10"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://schema.jqassistant.org/rule/v1.10 http://schema.jqassistant.org/rule/jqassistant-rule-v1.10.xsd">

    <concept id="jax-rs:PathResource">
        <description>Abstract concept that returns all types labeled with "JaxRS" and "PathResource".</description>
        <cypher><![CDATA[
            MATCH
              (t:Type:JaxRS:PathResource)
            RETURN
              t AS PathResource
    ]]></cypher>
    </concept>

</jqassistant-rules>